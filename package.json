{
  "name": "browser-esm-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "build:runtime": "esbuild ./node_modules/sucrase/dist/index.js --bundle --format=iife --global-name=Sucrase --outfile=./public/sucrase.browser.js --minify --footer:js=\"globalThis.Sucrase=Sucrase;\"",
    "preview": "vite preview --host 0.0.0.0",
    "test:sandbox": "bun scripts/smoke-sandbox.mjs",
    "test:preview": "bun scripts/smoke-preview.mjs",
    "test:typecheck": "bun scripts/smoke-typecheck.mjs",
    "test:agent-ui": "bun scripts/smoke-agent-ui.mjs",
    "test:ddb": "bun scripts/smoke-ddb.mjs",
    "test": "bun run test:sandbox && bun run test:preview && bun run test:typecheck && bun run test:agent-ui && bun run test:ddb",
    "postinstall": "bun run build:runtime"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.7",
    "@qzsy/dynamic-db-client": "^0.1.1",
    "@typescript/vfs": "^1.6.4",
    "ai": "^7.0.19",
    "ai-elements": "^1.9.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript-browser": "npm:typescript@5.9.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@qzsy/dynamic-db-cli": "^0.1.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "sucrase": "^3.35.0",
    "typescript": "7",
    "vite": "^7.0.0"
  }
}
