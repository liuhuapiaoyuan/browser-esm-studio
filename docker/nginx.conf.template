# Substituted at container start by nginx image envsubst
# (see /docker-entrypoint.d/20-envsubst-on-templates.sh).

server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    client_max_body_size 32m;

    # Streaming / long LLM & image calls
    proxy_http_version 1.1;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_read_timeout 600s;
    proxy_send_timeout 600s;
    proxy_connect_timeout 60s;

    location = /healthz {
        access_log off;
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    # ── /openai-proxy → AI_PROXY_TARGET (strip prefix) ─────────────
    # Browser: /openai-proxy/v1/... → {AI_PROXY_TARGET}/v1/...
    location /openai-proxy/ {
        proxy_pass ${AI_PROXY_TARGET}/;
        proxy_ssl_server_name on;
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    location = /openai-proxy {
        return 308 /openai-proxy/;
    }

    # ── /ddb → DYNAMIC_DB_BASE_URL + identity headers ──────────────
    location /ddb/ {
        proxy_pass ${DYNAMIC_DB_BASE_URL}/;
        proxy_ssl_server_name on;
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-User-Id ${DDB_USER_ID};
        proxy_set_header X-User-Roles ${DDB_ROLES};
        proxy_set_header Connection "";
    }

    location = /ddb {
        return 308 /ddb/;
    }

    # ── /lite-image-proxy → LITE_IMAGE_PROXY_TARGET ────────────────
    # Optional Authorization inject: include generated by 15-lite-image-auth.sh
    location /lite-image-proxy/ {
        proxy_pass ${LITE_IMAGE_PROXY_TARGET}/;
        proxy_ssl_server_name on;
        proxy_set_header Host $proxy_host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        include /etc/nginx/snippets/lite-image-auth.conf;
    }

    location = /lite-image-proxy {
        return 308 /lite-image-proxy/;
    }

    # Service Worker / static assets — no aggressive HTML caching
    location ~* \.(js|css|png|jpg|jpeg|gif|webp|svg|ico|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    # SPA fallback
    location / {
        try_files $uri $uri/ /index.html;
    }
}
