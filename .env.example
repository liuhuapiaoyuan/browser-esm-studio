# OpenAI-compatible API (ChatGPT-style). Copied values are defaults for the settings UI.
# Prefer configuring in the app UI; keys stored in localStorage stay local.

# Dev proxy target (Vite). Browser calls /openai-proxy/v1 → this host.
VITE_AI_PROXY_TARGET=https://api.openai.com

# Defaults shown in settings (optional)
VITE_AI_BASE_URL=/openai-proxy/v1
VITE_AI_MODEL=gpt-4o
# VITE_AI_API_KEY=

# Dynamic DB (Vite /ddb proxy → provider; Agent + Preview share this)
DYNAMIC_DB_BASE_URL=https://dynamic-db.b.nps.qzsyzn.com
VITE_DYNAMIC_DB_BASE_URL=https://dynamic-db.b.nps.qzsyzn.com
VITE_DDB_USER_ID=dev-user
VITE_DDB_ROLES=admin

# Lite image (Vite /lite-image-proxy → SiliconFlow; Agent image.* CLI)
# Prefer non-VITE key so the proxy injects Authorization (browser need not hold the secret).
LITE_IMAGE_PROXY_TARGET=https://api.siliconflow.cn
# LITE_IMAGE_API_KEY=
# SILICONFLOW_API_KEY=
# Optional browser override (defaults to /lite-image-proxy/v1)
# VITE_LITE_IMAGE_BASE_URL=/lite-image-proxy/v1
# VITE_LITE_IMAGE_MODEL=Kwai-Kolors/Kolors

# Docker / nginx runtime (same proxy paths as Vite; pass with docker run -e)
# AI_PROXY_TARGET=https://api.openai.com
# DYNAMIC_DB_BASE_URL=https://dynamic-db.b.nps.qzsyzn.com
# DDB_USER_ID=dev-user
# DDB_ROLES=admin
# LITE_IMAGE_PROXY_TARGET=https://api.siliconflow.cn
# LITE_IMAGE_API_KEY=
